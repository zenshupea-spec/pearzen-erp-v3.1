NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (used for EMP-number user lookups during Field PWA login)
SUPABASE_SERVICE_ROLE_KEY=

# Field PWA login strategy:
# Your Phase 1 blueprint says "passwordless", but Supabase sign-in requires a credential.
# These templates define the credential derivation from the entered EMP number.
FIELD_PWA_AUTH_EMAIL_TEMPLATE={{empNumber}}
FIELD_PWA_AUTH_PASSWORD_TEMPLATE={{empNumber}}

