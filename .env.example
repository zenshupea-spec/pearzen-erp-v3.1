# Copy to .env.seed.tmp or each app's .env.local (or run: npm run wire:backend)
# Values: Supabase → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — seeds, bulk import, Field/SM login APIs (never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=

# Optional — run SQL migrations from CLI (npm run db:apply-md-settings)
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
# SUPABASE_DB_PASSWORD=          # or set DATABASE_URL; used by npm run db:apply-epf-columns
# SUPABASE_ACCESS_TOKEN=          # https://supabase.com/dashboard/account/tokens

# Back-office HR: encrypt NIC/phone at rest (exactly 32 characters)
# Exactly 32 characters — encrypts NIC, phone, passport, address, and bank fields in Master Nominal Roll
ENCRYPTION_KEY=

# Field PWA: auth derived from EPF no on MNR (must match users created in Supabase Auth)
FIELD_PWA_AUTH_EMAIL_TEMPLATE={{epfNo}}@pearzen.local
FIELD_PWA_AUTH_PASSWORD_TEMPLATE={{epfNo}}

# Cross-app links (local dev ports; production defaults to sm./field.{NEXT_PUBLIC_TENANT_BASE_DOMAIN})
NEXT_PUBLIC_FIELD_PWA_URL=http://127.0.0.1:3001
NEXT_PUBLIC_SM_PWA_URL=http://127.0.0.1:3003
NEXT_PUBLIC_BACK_OFFICE_PORT=3002
NEXT_PUBLIC_CLIENT_PWA_URL=http://127.0.0.1:3000

# Public café customer menu — separate deploy; never point this domain at back-office
NEXT_PUBLIC_CUSTOMER_MENU_URL=https://tasha.lk
NEXT_PUBLIC_CUSTOMER_MENU_HOST=tasha.lk
# Company UUID baked into the public menu app (get_cafe_public_menu RPC)
NEXT_PUBLIC_CUSTOMER_MENU_COMPANY_ID=29fbb2ff-6aa6-46c4-8b2d-d19eebb2874e

# PayHere card checkout (client-pwa / tasha.lk) — https://www.payhere.lk
# Use sandbox keys while testing; set PAYHERE_SANDBOX=false for production.
PAYHERE_MERCHANT_ID=
PAYHERE_MERCHANT_SECRET=
PAYHERE_SANDBOX=true
# Server-only — PayHere notify webhook + order lookup (never expose to browser)
# SUPABASE_SERVICE_ROLE_KEY=  (already set above)

# Back-office public URL — required for Shalom OTA iCal links (Booking.com / Airbnb cannot use localhost)
# NEXT_PUBLIC_BACK_OFFICE_URL=https://cvs.pearzen.tech

# Multi-tenant subdomains ({slug}.pearzen.tech in production)
NEXT_PUBLIC_TENANT_BASE_DOMAIN=pearzen.tech
NEXT_PUBLIC_DEV_TENANT_SLUG=cvs
NEXT_PUBLIC_BACK_OFFICE_PORT=3002
# Set true once *.pearzen.tech DNS is pointed at back-office deploy
# NEXT_PUBLIC_TENANT_SUBDOMAINS_LIVE=true

# Optional — automate DNS + Vercel via: npm run connect:pearzen-tech
# VERCEL_TOKEN=                    # vercel.com/account/settings/tokens
# VERCEL_TEAM_ID=                  # if project is under a team

# Classic Venture public security site — npm run connect:classicventure-security
# Serves marketing pages + /clientlogin only. Staff portals stay on cvs.pearzen.tech.
# NEXT_PUBLIC_SECURITY_WEBSITE_HOST=classicventuresecurity.com

# Customer menu DNS (tasha.lk) — npm run connect:customer-menu
# CLOUDFLARE_API_TOKEN=            # Cloudflare → My Profile → API Tokens → Edit zone DNS
# PORKBUN_API_KEY=                 # porkbun.com/account/api
# PORKBUN_SECRET_API_KEY=

# SaaS Forge — comma-separated Google emails for platform operator login (/login/forge)
# Falls back to forge_settings DB row, then defaults below when unset.
FORGE_OPERATOR_EMAILS=zenshupea@gmail.com,shauvvvv@gmail.com

# Back-office geofence map preview (Google Maps JavaScript API — Maps JavaScript API enabled)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional: back-office geofence for OM/HR/FM dashboards
# HEAD_OFFICE_LAT=6.9271
# HEAD_OFFICE_LNG=79.8612
# HEAD_OFFICE_RADIUS_KM=50

# Optional: target company for seed scripts
# SEED_COMPANY_ID=9111dd55-9935-4e26-a630-60e36dcb57b5

# Fleet telematics webhook — POST /api/fleet/telematics (Bearer token)
# FLEET_TELEMATICS_WEBHOOK_SECRET=
