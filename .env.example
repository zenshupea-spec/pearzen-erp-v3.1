# Copy to .env.seed.tmp or each app's .env.local (or run: npm run wire:backend)
# Values: Supabase → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — seeds, bulk import, Field/SM login APIs (never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=

# Optional — run SQL migrations from CLI (npm run db:apply-md-settings)
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
# SUPABASE_DB_PASSWORD=          # or set DATABASE_URL; used by npm run db:apply-epf-columns
# SUPABASE_ACCESS_TOKEN=          # https://supabase.com/dashboard/account/tokens

# Back-office HR: encrypt NIC/phone at rest (exactly 32 characters)
ENCRYPTION_KEY=

# Field PWA: auth derived from EPF no on MNR (must match users created in Supabase Auth)
FIELD_PWA_AUTH_EMAIL_TEMPLATE={{epfNo}}@pearzen.local
FIELD_PWA_AUTH_PASSWORD_TEMPLATE={{epfNo}}

# Cross-app links (local dev ports)
NEXT_PUBLIC_FIELD_PWA_URL=http://127.0.0.1:3001
NEXT_PUBLIC_SM_PWA_URL=http://127.0.0.1:3003
NEXT_PUBLIC_BACK_OFFICE_PORT=3002

# Multi-tenant subdomains ({slug}.pearzen.com)
NEXT_PUBLIC_TENANT_BASE_DOMAIN=pearzen.com
NEXT_PUBLIC_DEV_TENANT_SLUG=classic-venture
NEXT_PUBLIC_BACK_OFFICE_PORT=3002
# Set true once *.pearzen.com DNS is pointed at back-office deploy
# NEXT_PUBLIC_TENANT_SUBDOMAINS_LIVE=true

# SaaS Forge — comma-separated Google emails for platform operator login (/login/forge)
# Falls back to forge_settings DB row, then defaults below when unset.
FORGE_OPERATOR_EMAILS=zenshupea@gmail.com,shauvvvv@gmail.com

# Optional: back-office geofence for OM/HR/FM dashboards
# HEAD_OFFICE_LAT=6.9271
# HEAD_OFFICE_LNG=79.8612
# HEAD_OFFICE_RADIUS_KM=50

# Optional: target company for seed scripts
# SEED_COMPANY_ID=9111dd55-9935-4e26-a630-60e36dcb57b5
