cat << 'EOF' > apps/back-office/app/executive/settings/page.tsx
import { cookies } from 'next/headers';
import { createSupabaseServerClient } from '../../../../../packages/supabase/server';
import SettingsClient from './SettingsClient';

export const dynamic = "force-dynamic";

export default async function ExecutiveSettingsPage() {
  const cookieStore = await cookies();
  const supabase = await createSupabaseServerClient(cookieStore);

  const { data: companies } = await supabase.from('companies').select('id, name').limit(1);
  const companyId = companies?.[0]?.id;

  if (!companyId) {
    return (
      <main className="min-h-screen bg-zinc-950 text-slate-200 p-8 flex items-center justify-center">
        <div className="text-zinc-500 font-mono">❌ SYSTEM HALTED: NO ACTIVE COMPANY FOUND.</div>
      </main>
    );
  }

  const { data: settingsData } = await supabase
    .from('md_settings')
    .select('*')
    .eq('company_id', companyId)
    .single();

  const { data: empData } = await supabase
    .from('employees')
    .select('rank, basic_salary')
    .eq('company_id', companyId)
    .neq('status', 'RESIGNED')
    .neq('status', 'TERMINATED');

  const rankMap = new Map<string, number>();
  if (empData) {
    empData.forEach((emp) => {
      if (emp.rank && !rankMap.has(emp.rank.toUpperCase())) {
        rankMap.set(emp.rank.toUpperCase(), emp.basic_salary);
      }
    });
  }

  const rankStats = Array.from(rankMap.entries()).map(([rank, basic_salary]) => ({
    rank,
    basic_salary,
  })).sort((a, b) => a.rank.localeCompare(b.rank));

  return (
    <main className="min-h-screen bg-zinc-950 text-slate-200 p-4 md:p-8">
      <div className="max-w-6xl mx-auto space-y-8">
        <h1 className="text-3xl font-bold text-white tracking-tight uppercase">Executive Vault</h1>
        <SettingsClient 
          initialSettings={settingsData || {}} 
          rankStats={rankStats} 
          companyId={companyId} 
        />
      </div>
    </main>
  );
}
EOF