{
  "name": "pearzen-erp",
  "private": true,
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:kill": "sh -c 'for port in 3000 3001 3002 3003 3004 3005; do lsof -ti:$port 2>/dev/null | xargs kill -9 2>/dev/null; done; rm -rf apps/*/.next'",
    "dev": "sh scripts/dev-start.sh",
    "dev:lan-pwas": "sh scripts/dev-lan-pwas.sh",
    "dev:restart": "npm run dev:kill && turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean",
    "db:invoice-setup": "node scripts/run-invoice-setup.mjs",
    "db:sync-invoice-md": "node scripts/sync-invoice-md-settings.mjs",
    "db:md-settings-sql": "node scripts/print-md-settings-migration.mjs",
    "db:apply-md-settings": "node scripts/apply-md-settings-migration.mjs",
    "db:apply-epf-columns": "node scripts/apply-employees-personal-columns.mjs",
    "db:apply-mnr-columns": "node scripts/apply-employees-mnr-columns.mjs",
    "provision:guard-portal": "node scripts/provision-guard-portal-auth.mjs",
    "seed:hr-employees": "node scripts/seed-hr-dummy-employees.mjs",
    "wire:backend": "node scripts/wire-backend-env.mjs",
    "check:backend": "node scripts/check-backend.mjs",
    "seed:scale-demo": "node scripts/seed-scale-demo.mjs",
    "seed:scale-demo:purge": "SEED_PURGE=1 node scripts/seed-scale-demo.mjs --purge",
    "seed:sync-demo": "node scripts/seed-sync-demo.mjs",
    "seed:master-hub": "node scripts/seed-master-hub-operational.mjs",
    "seed:cafe": "node scripts/seed-cafe-operational.mjs",
    "seed:mnr": "node scripts/seed-mnr-operational.mjs",
    "verify:master-hub": "node scripts/verify-master-hub.mjs",
    "walkthrough:md": "node scripts/walkthrough-md-portal.mjs",
    "audit:migrations": "node scripts/audit-migration-drift.mjs",
    "db:reset-baseline": "node scripts/reset-tenant-baseline.mjs",
    "db:provision-tenant": "node scripts/provision-tenant.mjs",
    "db:apply-tenant-host": "node scripts/apply-tenant-host-migration.mjs",
    "db:apply-schema-catchup": "node scripts/apply-schema-catchup.mjs",
    "db:apply-fleet-assets": "node scripts/apply-fleet-assets-migration.mjs",
    "db:apply-fleet-telematics": "node scripts/apply-fleet-telematics-migration.mjs",
    "db:apply-cafe-card-payment": "node scripts/apply-cafe-card-payment-migration.mjs",
    "db:apply-cafe-cash-payment": "node scripts/apply-cafe-cash-payment-migration.mjs",
    "db:apply-cafe-customers": "node scripts/apply-cafe-customers-migration.mjs",
    "db:apply-deductions-admin": "node scripts/apply-deductions-admin-migration.mjs",
    "db:apply-discrepancy-integrity": "node scripts/apply-discrepancy-integrity-migration.mjs",
    "db:apply-uniform-suppliers": "node scripts/apply-uniform-suppliers-migration.mjs",
    "db:apply-fm-deduction-plans": "node scripts/apply-fm-deduction-plans-migration.mjs",
    "db:apply-employee-allowances": "node scripts/apply-employee-allowances-migration.mjs",
    "db:apply-payroll-runs": "node scripts/apply-payroll-runs-migration.mjs",
    "db:apply-md-portal": "node scripts/apply-md-portal-migration.mjs",
    "db:apply-salary-advances": "node scripts/apply-salary-advances-migration.mjs",
    "db:apply-cafe-customer-spend-on-accept": "node scripts/apply-cafe-customer-spend-on-accept-migration.mjs",
    "setup:customer-menu-vercel-env": "node scripts/setup-customer-menu-vercel-env.mjs",
    "seed:fleet-telematics": "node scripts/seed-fleet-telematics-demo.mjs",
    "db:schema-catchup-sql": "node -e \"console.log(require('fs').readFileSync('packages/supabase/migrations/20260606150000_schema_catchup_bundle.sql','utf8'))\"",
    "db:sm-portal-sql": "node scripts/apply-sm-portal-sql.mjs",
    "setup:tenant-production": "node scripts/setup-tenant-production.mjs",
    "connect:pearzen-tech": "node scripts/connect-pearzen-tech.mjs",
    "connect:classicventure-security": "node scripts/connect-classicventure-security.mjs",
    "connect:pearzen-pwas": "node scripts/connect-pearzen-pwas.mjs",
    "connect:customer-menu": "node scripts/connect-customer-menu.mjs",
    "setup:local-tenant-hosts": "sh scripts/local-tenant-hosts.sh",
    "setup": "npm run wire:backend && npm run check:backend",
    "setup:google-maps": "node scripts/setup-google-maps-key.mjs"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "pg": "^8.21.0",
    "postgres": "^3.4.9",
    "turbo": "*",
    "typescript": "*"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.1",
    "idb": "^8.0.3"
  }
}
